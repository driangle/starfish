{
  "name": "@starfish/p5",
  "version": "0.0.1",
  "description": "p5.js adapter for the Starfish realtime protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node build.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@starfish/client": "file:../../sdks/typescript"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
