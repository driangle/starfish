{
  "name": "@driangle/starfish-server",
  "version": "0.0.1",
  "description": "TypeScript server for the Starfish realtime protocol",
  "license": "MIT",
  "author": "Starfish Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/driangle/starfish",
    "directory": "servers/typescript"
  },
  "keywords": [
    "starfish",
    "realtime",
    "websockets",
    "collaborative",
    "protocol",
    "server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "starfish-server": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
